# Hitech RAG Chatbot - Environment Variables
# PostgreSQL + Neon Database Edition

# ============================================
# REQUIRED: PostgreSQL Database (Neon)
# ============================================
# Get your connection string from: https://neon.tech
# Format: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://username:password@ep-xxx-xxx.us-east-1.aws.neon.tech/hitech_chatbot?sslmode=require"

# ============================================
# Application
# ============================================
APP_NAME="Hitech RAG Chatbot"
DEBUG=false
BACKEND_URL="http://localhost:8000"

# ============================================
# Pinecone Vector Store
# ============================================
# Get API key from: https://app.pinecone.io
PINECONE_API_KEY="your-pinecone-api-key"
PINECONE_ENVIRONMENT="gcp-starter"
PINECONE_INDEX_NAME="hitech-kb-index"
PINECONE_HOST="https://your-index.svc.environment.pinecone.io"
PINECONE_DIMENSION=384

# ============================================
# Google Gemini AI
# ============================================
# Get API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-2.5-flash-preview-05-20"
GEMINI_TEMPERATURE=0.3
GEMINI_MAX_TOKENS=2048

# ============================================
# RAG Configuration
# ============================================
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ============================================
# Session & Conversation
# ============================================
SESSION_TTL_HOURS=24
MAX_CONVERSATION_HISTORY=10

# ============================================
# Web Scraping (Knowledge Base)
# ============================================
SCRAPE_BASE_URL="https://www.hitech.sa"
SCRAPE_MAX_PAGES=100
SCRAPE_DELAY=1.0

# ============================================
# CORS (for widget embedding)
# ============================================
# Use "*" for all origins or comma-separated list
CORS_ORIGINS="*"

# ============================================
# Company Configuration
# ============================================
CHATBOT_NAME="Hitech Assistant"
COMPANY_NAME="Hitech Steel Industries"